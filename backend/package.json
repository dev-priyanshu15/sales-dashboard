{
  "name": "sales-pipeline-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Sales data processing & analytics pipeline - backend API and workers",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently -n api,worker -c blue,green \"npm:dev:api\" \"npm:dev:worker\"",
    "dev:api": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/workers/index.ts",
    "worker": "tsx watch src/workers/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.34.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "concurrently": "^10.0.3",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
