NODE_ENV=development
PORT=4000

# Must match the credentials/port in the root .env (docker-compose)
DATABASE_URL=postgres://sales_user:sales_pass@localhost:5434/sales_db

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=dev-secret-change-me-in-production
JWT_EXPIRES_IN=1d

# Artificial per-row processing delay (ms) to simulate real cost
ROW_PROCESSING_DELAY_MS=25
# How many rows are processed concurrently by the worker pool
WORKER_CONCURRENCY=10
